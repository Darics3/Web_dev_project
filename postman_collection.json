{
  "info": {
    "name": "Baibol API",
    "_postman_id": "baibol-kbtu-2024",
    "description": "Complete API collection for Baibol Store Management Platform\n\nSetup:\n1. Run Django backend: python manage.py runserver\n2. Register a user via POST /api/auth/register/\n3. Copy the access token into the collection variable {{token}}\n4. All protected endpoints will use Bearer {{token}} automatically",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8000" },
    { "key": "token",   "value": "PASTE_YOUR_ACCESS_TOKEN_HERE" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/register/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"username\": \"testuser\", \"email\": \"test@example.com\", \"password\": \"test1234\", \"password2\": \"test1234\"}"
            }
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "body": "{\"message\": \"User registered successfully.\", \"user\": {\"id\": 1, \"username\": \"testuser\", \"email\": \"test@example.com\"}, \"tokens\": {\"refresh\": \"eyJ...\", \"access\": \"eyJ...\"}}"
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/login/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"username\": \"testuser\", \"password\": \"test1234\"}"
            }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\"message\": \"Login successful.\", \"user\": {\"id\": 1, \"username\": \"testuser\", \"email\": \"test@example.com\"}, \"tokens\": {\"refresh\": \"eyJ...\", \"access\": \"eyJ...\"}}"
            },
            {
              "name": "401 Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "body": "{\"error\": \"Invalid username or password.\"}"
            }
          ]
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/auth/me/",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          },
          "response": [
            {
              "name": "200 OK",
              "code": 200,
              "body": "{\"id\": 1, \"username\": \"testuser\", \"email\": \"test@example.com\"}"
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/logout/",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\"refresh\": \"YOUR_REFRESH_TOKEN\"}" }
          },
          "response": [
            { "name": "200 OK", "code": 200, "body": "{\"message\": \"Logged out successfully.\"}" }
          ]
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "List Categories",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/categories/",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          },
          "response": [
            {
              "name": "200 OK",
              "code": 200,
              "body": "[{\"id\": 1, \"name\": \"Electronics\", \"description\": \"Electronic goods\", \"created_at\": \"2024-01-01T00:00:00Z\", \"product_count\": 5}]"
            }
          ]
        },
        {
          "name": "Create Category",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/categories/",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\"name\": \"Electronics\", \"description\": \"Electronic devices and accessories\"}" }
          },
          "response": [
            { "name": "201 Created", "code": 201, "body": "{\"id\": 1, \"name\": \"Electronics\", \"description\": \"Electronic devices\", \"created_at\": \"2024-01-01T00:00:00Z\", \"product_count\": 0}" }
          ]
        },
        {
          "name": "Update Category",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/categories/1/",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\"name\": \"Electronics & Gadgets\", \"description\": \"Updated description\"}" }
          },
          "response": [
            { "name": "200 OK", "code": 200, "body": "{\"id\": 1, \"name\": \"Electronics & Gadgets\", \"description\": \"Updated description\", \"product_count\": 0}" }
          ]
        },
        {
          "name": "Delete Category",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/categories/1/",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          },
          "response": [
            { "name": "200 OK", "code": 200, "body": "{\"message\": \"Category deleted.\"}" }
          ]
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/products/",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products", ""],
              "query": [
                { "key": "search",   "value": "nike",  "disabled": true },
                { "key": "category", "value": "1",     "disabled": true }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          },
          "response": [
            {
              "name": "200 OK",
              "code": 200,
              "body": "[{\"id\": 1, \"name\": \"Nike Air Max\", \"description\": \"Running shoes\", \"price\": \"25000.00\", \"stock\": 50, \"category\": 1, \"category_name\": \"Footwear\", \"created_by\": 1, \"created_by_name\": \"testuser\", \"created_at\": \"2024-01-01T00:00:00Z\"}]"
            }
          ]
        },
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/products/",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\"name\": \"Nike Air Max\", \"description\": \"Premium running shoes\", \"price\": 25000, \"stock\": 50, \"category\": 1}" }
          },
          "response": [
            { "name": "201 Created", "code": 201, "body": "{\"id\": 1, \"name\": \"Nike Air Max\", \"price\": \"25000.00\", \"stock\": 50}" }
          ]
        },
        {
          "name": "Get Product",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/products/1/",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          },
          "response": [
            { "name": "200 OK", "code": 200, "body": "{\"id\": 1, \"name\": \"Nike Air Max\", \"price\": \"25000.00\", \"stock\": 50}" },
            { "name": "404 Not Found", "code": 404, "body": "{\"error\": \"Product not found.\"}" }
          ]
        },
        {
          "name": "Update Product (Full)",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/products/1/",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\"name\": \"Nike Air Max 2024\", \"description\": \"Updated\", \"price\": 28000, \"stock\": 45, \"category\": 1}" }
          },
          "response": [
            { "name": "200 OK", "code": 200, "body": "{\"id\": 1, \"name\": \"Nike Air Max 2024\", \"price\": \"28000.00\", \"stock\": 45}" }
          ]
        },
        {
          "name": "Partial Update Product",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/api/products/1/",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\"stock\": 100}" }
          },
          "response": [
            { "name": "200 OK", "code": 200, "body": "{\"id\": 1, \"name\": \"Nike Air Max\", \"stock\": 100}" }
          ]
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/products/1/",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          },
          "response": [
            { "name": "204 No Content", "code": 204, "body": "" }
          ]
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "List Orders",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/orders/",
              "query": [{ "key": "status", "value": "pending", "disabled": true }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          },
          "response": [
            {
              "name": "200 OK",
              "code": 200,
              "body": "[{\"id\": 1, \"customer_name\": \"Aigerim Bekova\", \"status\": \"pending\", \"status_display\": \"Pending\", \"total_price\": \"50000.00\", \"items\": [{\"id\": 1, \"product\": 1, \"product_name\": \"Nike Air Max\", \"quantity\": 2, \"price\": \"25000.00\"}]}]"
            }
          ]
        },
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/orders/",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"customer_name\": \"Aigerim Bekova\", \"customer_phone\": \"+77771234567\", \"notes\": \"Deliver ASAP\", \"items\": [{\"product\": 1, \"quantity\": 2}]}"
            }
          },
          "response": [
            { "name": "201 Created", "code": 201, "body": "{\"id\": 1, \"customer_name\": \"Aigerim Bekova\", \"status\": \"pending\", \"total_price\": \"50000.00\"}" }
          ]
        },
        {
          "name": "Update Order Status",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/api/orders/1/",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\"status\": \"completed\"}" }
          },
          "response": [
            { "name": "200 OK", "code": 200, "body": "{\"id\": 1, \"status\": \"completed\", \"status_display\": \"Completed\"}" }
          ]
        },
        {
          "name": "Delete Order",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/orders/1/",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          },
          "response": [
            { "name": "204 No Content", "code": 204, "body": "" }
          ]
        }
      ]
    }
  ]
}
